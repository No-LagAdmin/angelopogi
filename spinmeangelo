local function createSwitch(titleText, toggleKey, callback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 45)
    row.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    row.Parent = container
    Instance.new("UICorner", row)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.7, 0, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.Text = titleText
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = row
    
    local track = Instance.new("TextButton")
    track.Size = UDim2.new(0, 40, 0, 20)
    track.Position = UDim2.new(1, -50, 0.5, -10)
    track.BackgroundColor3 = toggles[toggleKey] and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(60, 60, 70)
    track.Text = ""
    track.Parent = row
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    
    track.MouseButton1Click:Connect(function()
        toggles[toggleKey] = not toggles[toggleKey]
        track.BackgroundColor3 = toggles[toggleKey] and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(60, 60, 70)
        saveConfig()
        if callback then task.spawn(function() callback(toggles[toggleKey]) end) end
    end)
    if toggles[toggleKey] and callback then task.spawn(function() callback(true) end) end
end

local function createDropdown(titleText, list, selectionTable, toggleKey)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 45)
    frame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    frame.ClipsDescendants = true
    frame.Parent = container
    Instance.new("UICorner", frame)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 45)
    btn.Text = "  " .. titleText
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamBold
    btn.BackgroundTransparency = 1
    btn.TextXAlignment = 0
    btn.Parent = frame

    local inner = Instance.new("ScrollingFrame")
    inner.Size = UDim2.new(1, -20, 0, 100)
    inner.Position = UDim2.new(0, 10, 0, 50)
    inner.BackgroundTransparency = 1
    inner.AutomaticCanvasSize = Enum.AutomaticSize.Y
    inner.Parent = frame
    local grid = Instance.new("UIGridLayout", inner); grid.CellSize = UDim2.new(0, 90, 0, 25)

    for _, name in pairs(list) do
        local opt = Instance.new("TextButton")
        opt.Text = name
        opt.BackgroundColor3 = selectionTable[name] and Color3.fromRGB(0, 100, 255) or Color3.fromRGB(40, 40, 50)
        opt.TextColor3 = Color3.new(1,1,1)
        opt.Font = Enum.Font.Gotham
        opt.TextSize = 10
        opt.Parent = inner
        Instance.new("UICorner", opt)
        opt.MouseButton1Click:Connect(function()
            selectionTable[name] = not selectionTable[name] or nil
            opt.BackgroundColor3 = selectionTable[name] and Color3.fromRGB(0, 100, 255) or Color3.fromRGB(40, 40, 50)
            saveConfig()
        end)
    end

    btn.MouseButton1Click:Connect(function()
        local isExp = frame.Size.Y.Offset == 45
        TweenService:Create(frame, TweenInfo.new(0.3), {Size = isExp and UDim2.new(1, 0, 0, 160) or UDim2.new(1, 0, 0, 45)}):Play()
    end)
    
    createSwitch("Enable " .. titleText, toggleKey)
end

