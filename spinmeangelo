local function makeToggle(txt, key)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0.92, 0, 0, 40)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 45); btn.Text = txt; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.Gotham
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function()
        _G.toggles[key] = not _G.toggles[key]
        btn.BackgroundColor3 = _G.toggles[key] and Color3.fromRGB(0, 180, 90) or Color3.fromRGB(35, 35, 45)
    end)
end

local function makeSelectGrid(titleTxt, data, target)
    local lab = Instance.new("TextLabel", scroll)
    lab.Size = UDim2.new(0.9, 0, 0, 25); lab.Text = titleTxt; lab.TextColor3 = Color3.fromRGB(200,200,200); lab.BackgroundTransparency = 1; lab.Font = Enum.Font.GothamBold

    local grid = Instance.new("Frame", scroll)
    grid.Size = UDim2.new(0.92, 0, 0, 140); grid.BackgroundColor3 = Color3.fromRGB(25, 25, 32)
    Instance.new("UICorner", grid)
    
    local gScroll = Instance.new("ScrollingFrame", grid)
    gScroll.Size = UDim2.new(1, -10, 1, -10); gScroll.Position = UDim2.new(0, 5, 0, 5); gScroll.BackgroundTransparency = 1; gScroll.ScrollBarThickness = 2; gScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    local gLay = Instance.new("UIGridLayout", gScroll); gLay.CellSize = UDim2.new(0, 95, 0, 28); gLay.Padding = UDim2.new(0, 5, 0, 5)

    for _, name in pairs(data) do
        local b = Instance.new("TextButton", gScroll)
        b.Text = name; b.TextSize = 10; b.TextColor3 = Color3.new(1,1,1); b.BackgroundColor3 = Color3.fromRGB(45, 45, 55); Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function()
            target[name] = not target[name]
            b.BackgroundColor3 = target[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(45, 45, 55)
        end)
    end
end

