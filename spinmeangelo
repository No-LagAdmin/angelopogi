    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = track
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local selectBtn = Instance.new("TextButton")
    selectBtn.Size = UDim2.new(1, -24, 0, 35)
    selectBtn.Position = UDim2.new(0, 12, 0, 50)
    selectBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    selectBtn.Text = "Select: " .. selections[key]
    selectBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    selectBtn.Font = Enum.Font.Gotham
    selectBtn.TextSize = 12
    selectBtn.Parent = row
    Instance.new("UICorner", selectBtn).CornerRadius = UDim.new(0, 6)

    local active = false
