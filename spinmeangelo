local function makeToggle(txt, key)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0.94, 0, 0, 42)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40); btn.Text = txt; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.Gotham
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function()
        _G.toggles[key] = not _G.toggles[key]
        btn.BackgroundColor3 = _G.toggles[key] and Color3.fromRGB(0, 180, 90) or Color3.fromRGB(30, 30, 40)
    end)
end

local function makeSelectionArea(labelTxt, items, target)
    local titleLab = Instance.new("TextLabel", scroll)
    titleLab.Size = UDim2.new(0.9, 0, 0, 20); titleLab.Text = labelTxt; titleLab.TextColor3 = Color3.fromRGB(0, 255, 150)
    titleLab.BackgroundTransparency = 1; titleLab.Font = Enum.Font.GothamBold; titleLab.TextSize = 13

    local container = Instance.new("Frame", scroll)
    container.Size = UDim2.new(0.94, 0, 0, 160); container.BackgroundColor3 = Color3.fromRGB(20, 20, 28)
    Instance.new("UICorner", container)

    local internalScroll = Instance.new("ScrollingFrame", container)
    internalScroll.Size = UDim2.new(1, -10, 1, -10); internalScroll.Position = UDim2.new(0, 5, 0, 5)
    internalScroll.BackgroundTransparency = 1; internalScroll.ScrollBarThickness = 2; internalScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    
    local grid = Instance.new("UIGridLayout", internalScroll)
    grid.CellSize = UDim2.new(0, 105, 0, 32); grid.Padding = UDim2.new(0, 6, 0, 6); grid.HorizontalAlignment = Enum.HorizontalAlignment.Center

    for _, name in pairs(items) do
        local b = Instance.new("TextButton", internalScroll)
        b.Text = name; b.TextSize = 10; b.TextColor3 = Color3.new(1,1,1); b.BackgroundColor3 = Color3.fromRGB(40, 40, 50); Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function()
            target[name] = not target[name]
            b.BackgroundColor3 = target[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(40, 40, 50)
        end)
    end
end

