local function makeToggle(txt, key)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0.95, 0, 0, 45)
    btn.BackgroundColor3 = _G.toggles[key] and Color3.fromRGB(0, 150, 80) or Color3.fromRGB(35, 35, 45)
    btn.Text = txt; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.Gotham; btn.TextSize = 13
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function()
        _G.toggles[key] = not _G.toggles[key]
        btn.BackgroundColor3 = _G.toggles[key] and Color3.fromRGB(0, 150, 80) or Color3.fromRGB(35, 35, 45)
        saveConfig()
    end)
end

local function makeMenu(titleTxt, items, targetTable)
    local label = Instance.new("TextLabel", scroll)
    label.Size = UDim2.new(1, 0, 0, 25); label.Text = titleTxt; label.TextColor3 = Color3.fromRGB(150, 150, 150)
    label.BackgroundTransparency = 1; label.Font = Enum.Font.GothamBold; label.TextSize = 12

    local gridFrame = Instance.new("Frame", scroll)
    gridFrame.Size = UDim2.new(0.95, 0, 0, 150) -- Fixed height for grid
    gridFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    Instance.new("UICorner", gridFrame)
    
    local gScroll = Instance.new("ScrollingFrame", gridFrame)
    gScroll.Size = UDim2.new(1, -10, 1, -10); gScroll.Position = UDim2.new(0, 5, 0, 5)
    gScroll.BackgroundTransparency = 1; gScroll.CanvasSize = UDim2.new(0,0,3,0); gScroll.ScrollBarThickness = 2
    local gLayout = Instance.new("UIGridLayout", gScroll)
    gLayout.CellSize = UDim2.new(0, 100, 0, 30); gLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    for _, name in pairs(items) do
        local b = Instance.new("TextButton", gScroll)
        b.Text = name; b.TextSize = 10; b.TextColor3 = Color3.new(1,1,1)
        b.BackgroundColor3 = targetTable[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(45, 45, 55)
        Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function()
            targetTable[name] = not targetTable[name]
            b.BackgroundColor3 = targetTable[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(45, 45, 55)
            saveConfig()
        end)
    end
end

