-- File Settings
local filename = "AngeloPogiHub_Config.json"

-- Logic Variables
local toggles = { Crates = false, Potions = false, AntiAFK = false, EquipBest = false, AutoCollect = false }
local selectedCrates = {}
local selectedPotions = {}

-- ==========================================
-- CONFIGURATION SYSTEM (FIXED)
-- ==========================================
local function saveConfig()
    local data = { 
        Toggles = toggles, 
        Crates = selectedCrates, 
        Potions = selectedPotions 
    }
    local success, err = pcall(function() 
        if writefile then 
            writefile(filename, HttpService:JSONEncode(data)) 
        end 
    end)
    if success then print("💾 Config Saved Successfully") else warn("❌ Save Error:", err) end
end

local function loadConfig()
    if isfile and isfile(filename) then
        local success, err = pcall(function()
            local decoded = HttpService:JSONDecode(readfile(filename))
            if decoded.Toggles then for k, v in pairs(decoded.Toggles) do toggles[k] = v end end
            if decoded.Crates then for k, v in pairs(decoded.Crates) do selectedCrates[k] = v end end
            if decoded.Potions then for k, v in pairs(decoded.Potions) do selectedPotions[k] = v end end
        end)
        if success then print("📂 Config Loaded") else warn("❌ Load Error:", err) end
    end
end

-- Initialize Config
loadConfig()

-- ==========================================
-- STABILITY UTILS
-- ==========================================
local function getMyPlot()
    local plots = workspace:FindFirstChild("Plots") or workspace:FindFirstChild("Tycoons")
    if not plots then return nil end
    for _, plot in pairs(plots:GetChildren()) do
        local owner = plot:FindFirstChild("Owner")
        if owner and (owner.Value == player.Name or tostring(owner.Value) == tostring(player.UserId)) then
            return plot
        end
    end
    return nil
end

