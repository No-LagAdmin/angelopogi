-- FIXED AUTO COLLECT (Server-Sided Remote Call)
task.spawn(function()
    while true do
        if toggles.AutoCollect then
            pcall(function()
                -- Direct remote call to collect money (Bypasses physics crashes)
                local remote = ReplicatedStorage:FindFirstChild("Events") and ReplicatedStorage.Events:FindFirstChild("Plot")
                if remote and remote:FindFirstChild("collectMoney") then
                    remote.collectMoney:FireServer()
                end
            end)
        end
        task.wait(1) -- Faster collection, zero lag
    end
end)

-- AUTO ACTIONS
task.spawn(function()
    while true do
        if toggles.Potions then
            for item, _ in pairs(selectedPotions) do
                pcall(function() ReplicatedStorage.Events.Potion.purchase:FireServer(item, 1) end)
                task.wait(0.5)
            end
        end
        if toggles.Crates then
            for item, _ in pairs(selectedCrates) do
                pcall(function() ReplicatedStorage.Events.Crate.purchase:FireServer(item, 1) end)
                task.wait(0.5)
            end
        end
        if toggles.EquipBest then
            pcall(function() ReplicatedStorage.Events.Plot.equipBest:InvokeServer() end)
        end
        task.wait(2)
    end
end)

