-- Dropdown Builder
local function createDropdownMenu(titleText, list, selectionTable, toggleKey)
    local outerFrame = Instance.new("Frame")
    outerFrame.Size = UDim2.new(0.95, 0, 0, 50); outerFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 35); outerFrame.ClipsDescendants = true; outerFrame.Parent = container
    Instance.new("UICorner", outerFrame)

    local topBar = Instance.new("TextButton")
    topBar.Size = UDim2.new(1, 0, 0, 50); topBar.Text = "  " .. titleText; topBar.TextColor3 = Color3.new(1,1,1); topBar.BackgroundTransparency = 1; topBar.TextXAlignment = Enum.TextXAlignment.Left; topBar.Parent = outerFrame

    local track = Instance.new("TextButton")
    track.Size = UDim2.new(0, 44, 0, 22); track.Position = UDim2.new(1, -55, 0, 14); track.BackgroundColor3 = toggles[toggleKey] and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(60, 60, 65); track.Text = ""; track.Parent = outerFrame
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)

    local listScroll = Instance.new("ScrollingFrame")
    listScroll.Size = UDim2.new(1, -20, 0, 130); listScroll.Position = UDim2.new(0, 10, 0, 55); listScroll.Visible = false; listScroll.Parent = outerFrame
    Instance.new("UIGridLayout", listScroll).CellSize = UDim2.new(0, 95, 0, 30)

    for _, itemName in pairs(list) do
        local btn = Instance.new("TextButton")
        btn.Text = itemName; btn.BackgroundColor3 = selectionTable[itemName] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(45, 45, 50); btn.Parent = listScroll
        Instance.new("UICorner", btn)
        btn.MouseButton1Click:Connect(function()
            selectionTable[itemName] = not selectionTable[itemName] or nil
            btn.BackgroundColor3 = selectionTable[itemName] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(45, 45, 50)
            saveConfig()
        end)
    end

    topBar.MouseButton1Click:Connect(function()
        local expanded = outerFrame.Size.Y.Offset == 50
        TweenService:Create(outerFrame, TweenInfo.new(0.3), {Size = expanded and UDim2.new(0.95, 0, 0, 200) or UDim2.new(0.95, 0, 0, 50)}):Play()
        listScroll.Visible = expanded
    end)

    track.MouseButton1Click:Connect(function()
        toggles[toggleKey] = not toggles[toggleKey]
        track.BackgroundColor3 = toggles[toggleKey] and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(60, 60, 65)
        saveConfig()
    end)
end

-- Switch Builder
local function createSwitch(titleText, toggleKey, callback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(0.95, 0, 0, 50); row.BackgroundColor3 = Color3.fromRGB(30, 30, 35); row.Parent = container
    Instance.new("UICorner", row)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.6, 0, 1, 0); label.Position = UDim2.new(0, 12, 0, 0); label.Text = titleText; label.TextColor3 = Color3.new(0.8,0.8,0.8); label.BackgroundTransparency = 1; label.TextXAlignment = Enum.TextXAlignment.Left; label.Parent = row
    
    local track = Instance.new("TextButton")
    track.Size = UDim2.new(0, 44, 0, 22); track.Position = UDim2.new(1, -55, 0.5, -11); track.BackgroundColor3 = toggles[toggleKey] and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(60, 60, 65); track.Text = ""; track.Parent = row
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)
    
    track.MouseButton1Click:Connect(function()
        toggles[toggleKey] = not toggles[toggleKey]
        track.BackgroundColor3 = toggles[toggleKey] and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(60, 60, 65)
        saveConfig()
        if callback then task.spawn(function() callback(toggles[toggleKey]) end) end
    end)
    if toggles[toggleKey] and callback then task.spawn(function() callback(true) end) end
end

