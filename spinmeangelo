-- AUTO COLLECT
task.spawn(function()
    while true do
        if toggles.AutoCollect then
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            local plot = getMyPlot()
            if root and plot then
                pcall(function()
                    for _, obj in pairs(plot:GetDescendants()) do
                        if obj:IsA("TouchTransmitter") then
                            firetouchinterest(obj.Parent, root, 0)
                            task.wait()
                            firetouchinterest(obj.Parent, root, 1)
                        end
                    end
                end)
            end
        end
        task.wait(3)
    end
end)

-- AUTO POTION
task.spawn(function()
    while true do
        if toggles.Potions then
            for item, _ in pairs(selectedPotions) do
                if not toggles.Potions then break end
                pcall(function() ReplicatedStorage.Events.Potion.purchase:FireServer(item, 1) end)
                task.wait(1.5)
            end
        end
        task.wait(2)
    end
end)

