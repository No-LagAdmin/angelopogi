-- CONFIGURATION SYSTEM
-- ==========================================
local function saveConfig()
    local data = { Toggles = toggles, Crates = selectedCrates, Potions = selectedPotions }
    pcall(function() if writefile then writefile(filename, HttpService:JSONEncode(data)) end end)
end

local function loadConfig()
    if isfile and isfile(filename) then
        pcall(function()
            local decoded = HttpService:JSONDecode(readfile(filename))
            if decoded.Toggles then for k, v in pairs(decoded.Toggles) do toggles[k] = v end end
            if decoded.Crates then for k, v in pairs(decoded.Crates) do selectedCrates[k] = v end end
            if decoded.Potions then for k, v in pairs(decoded.Potions) do selectedPotions[k] = v end end
        end)
    end
end

