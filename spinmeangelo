-- Config System
local fileName = "AngeloFullPowerConfig.json"
local function saveConfig()
    local data = {
        toggles = _G.toggles,
        crates = _G.selectedCrates,
        potions = _G.selectedPotions
    }
    pcall(function() writefile(fileName, HttpService:JSONEncode(data)) end)
end

local function loadConfig()
    if isfile(fileName) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(fileName)) end)
        if success then
            _G.toggles = data.toggles or _G.toggles
            _G.selectedCrates = data.crates or _G.selectedCrates
            _G.selectedPotions = data.potions or _G.selectedPotions
        end
    end
end

-- Global Logic Variables
_G.toggles = { AutoCollect = false, AntiAFK = false, Crates = false, Potions = false, EquipBest = false }
_G.selectedCrates = {}
_G.selectedPotions = {}
loadConfig()

