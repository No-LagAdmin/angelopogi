local function fireStrictRemote(categoryName, itemName)
    pcall(function()
        local events = ReplicatedStorage:FindFirstChild("Events")
        if events then
            local categoryFolder = events:FindFirstChild(categoryName)
            if categoryFolder then
                local remote = categoryFolder:FindFirstChild("purchase") or categoryFolder:FindFirstChild("use")
                if remote then remote:FireServer(itemName, 1) end
            end
        end
    end)
end

