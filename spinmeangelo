-- AUTO EQUIP BEST (Every 25 Seconds)
task.spawn(function()
    while true do
        if _G.toggles.EquipBest then
            pcall(function()
                ReplicatedStorage.Events.Plot.equipBest:FireServer()
            end)
        end
        task.wait(25)
    end
end)

-- AUTO COLLECT YEN (Deep-Scan Mode)
task.spawn(function()
    while true do
        if _G.toggles.AutoCollect then
            pcall(function()
                local char = player.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                local plot1 = workspace:FindFirstChild("Plots") and workspace.Plots:FindFirstChild("Plot1")
                
                if plot1 and root then
                    local slots = plot1:FindFirstChild("Slots")
                    if slots then
                        for i = 1, 12 do
                            local slot = slots:FindFirstChild(tostring(i))
                            if slot then
                                for _, part in pairs(slot:GetDescendants()) do
                                    if part:IsA("BasePart") and part:FindFirstChildOfClass("TouchInterest") then
                                        firetouchinterest(part, root, 0)
                                        task.wait(0.02)
                                        firetouchinterest(part, root, 1)
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end
        task.wait(5) -- 5-second interval
    end
end)

-- AUTO BUY/USE LOOP
task.spawn(function()
    while true do
        if _G.toggles.Crates then
            for crate, _ in pairs(_G.selectedCrates) do
                pcall(function() ReplicatedStorage.Events.Crate.purchase:FireServer(crate, 1) end)
                task.wait(0.5)
            end
        end
        if _G.toggles.Potions then
            for potion, _ in pairs(_G.selectedPotions) do
                pcall(function() ReplicatedStorage.Events.Potion.purchase:FireServer(potion, 1) end)
                task.wait(0.5)
            end
        end
        task.wait(2)
    end
end)

