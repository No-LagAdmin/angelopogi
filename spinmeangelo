-- FIXED CONFIGURATION SYSTEM
-- ==========================================
local function saveConfig()
    local data = {
        Toggles = toggles,
        Crates = selectedCrates,
        Potions = selectedPotions
    }
    local success, result = pcall(function()
        if writefile then
            writefile(filename, HttpService:JSONEncode(data))
        end
    end)
    if success then print("✅ Config Saved!") else warn("❌ Save Failed: " .. tostring(result)) end
end

local function loadConfig()
    local exists = pcall(function() return isfile(filename) end)
    if exists and isfile(filename) then
        local success, result = pcall(function()
            local decoded = HttpService:JSONDecode(readfile(filename))
            -- Merge Toggles
            if decoded.Toggles then
                for k, v in pairs(decoded.Toggles) do toggles[k] = v end
            end
            -- Merge Crates
            if decoded.Crates then
                for k, v in pairs(decoded.Crates) do selectedCrates[k] = v end
            end
            -- Merge Potions
            if decoded.Potions then
                for k, v in pairs(decoded.Potions) do selectedPotions[k] = v end
            end
        end)
        if success then print("✅ Config Loaded!") else warn("❌ Load Failed: " .. tostring(result)) end
    end
end

