                                    task.wait()
                                    firetouchinterest(parent, root, 1)
                                end
                            
                            -- Method 2: Proximity Prompts (Press E style)
                            elseif obj:IsA("ProximityPrompt") then
                                fireproximityprompt(obj)
                            end
