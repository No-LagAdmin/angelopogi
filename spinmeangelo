-- Components
local function createToggle(txt, key)
    local btn = Instance.new("TextButton", container)
    btn.Size = UDim2.new(0.96, 0, 0, 35)
    btn.BackgroundColor3 = toggles[key] and Color3.fromRGB(0, 150, 80) or Color3.fromRGB(30, 30, 40)
    btn.Text = txt; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.Gotham; btn.TextSize = 12
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function()
        toggles[key] = not toggles[key]
        btn.BackgroundColor3 = toggles[key] and Color3.fromRGB(0, 150, 80) or Color3.fromRGB(30, 30, 40)
        saveConfig()
    end)
end

local function createSelection(txt, list, selection)
    local frame = Instance.new("Frame", container)
    frame.Size = UDim2.new(0.96, 0, 0, 100); frame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    Instance.new("UICorner", frame)
    
    local lbl = Instance.new("TextLabel", frame)
    lbl.Size = UDim2.new(1, 0, 0, 25); lbl.Text = "  Select " .. txt; lbl.TextColor3 = Color3.new(0.6,0.6,0.6)
    lbl.BackgroundTransparency = 1; lbl.TextXAlignment = 0; lbl.Font = Enum.Font.Gotham; lbl.TextSize = 11

    local scroller = Instance.new("ScrollingFrame", frame)
    scroller.Size = UDim2.new(1, -10, 1, -30); scroller.Position = UDim2.new(0, 5, 0, 25)
    scroller.BackgroundTransparency = 1; scroller.AutomaticCanvasSize = 2; scroller.ScrollBarThickness = 0
    local grid = Instance.new("UIGridLayout", scroller); grid.CellSize = UDim2.new(0, 95, 0, 25)

    for _, name in pairs(list) do
        local opt = Instance.new("TextButton", scroller)
        opt.Text = name; opt.Font = Enum.Font.Gotham; opt.TextSize = 10
        opt.BackgroundColor3 = selection[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(40, 40, 50)
        opt.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", opt)
        
        opt.MouseButton1Click:Connect(function()
            if selection[name] then selection[name] = nil else selection[name] = true end
            opt.BackgroundColor3 = selection[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(40, 40, 50)
            saveConfig()
        end)
    end
end

