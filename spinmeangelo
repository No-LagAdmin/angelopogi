-- Functions
local function createToggleButton(parent, name, position, callback, size)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = size or UDim2.new(1, -20, 0, 40)
    btn.Position = position
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextScaled = true
    btn.Font = Enum.Font.Gotham
    btn.Parent = parent
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = btn
    
    btn.MouseButton1Click:Connect(callback)
    
    -- Hover effects
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(70, 70, 80)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        local color = toggles[name:lower()] and toggles[name:lower()].active and Color3.fromRGB(100, 200, 100) or Color3.fromRGB(50, 50, 60)
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = color}):Play()
    end)
    
    return btn
end

local function buyCrate(crateName)
    pcall(function()
        ReplicatedStorage.Events.Crate.purchase:FireServer(crateName, 1)
        print("✅ Bought " .. crateName .. " Crate")
    end)
end

local function buyPotion(potionName)
    pcall(function()
        ReplicatedStorage.Events.Potion.purchase:FireServer(potionName, 1)
        print("✅ Bought " .. potionName .. " Potion")
    end)
end

local function equipBest()
    pcall(function()
        ReplicatedStorage.Events.Plot.equipBest:InvokeServer()
        print("⚡ Equipped Best")
    end)
end

local function toggleCrates()
    toggles.crate.active = not toggles.crate.active
    local btn = mainFrame.CratesFrame.CrateToggle
    
    if toggles.crate.active then
        btn.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
        btn.Text = "🟢 Crates: ON (3s)"
        toggles.crate.connection = RunService.Heartbeat:Connect(function()
            if toggles.crate.active then
                wait(3)
                for _, crate in ipairs(crateList) do
                    buyCrate(crate)
                    wait(0.1)
                end
            end
        end)
    else
        btn.BackgroundColor3 = Color3.fromRGB(200, 100, 100)
        btn.Text = "🔴 Crates: OFF"
        if toggles.crate.connection then
            toggles.crate.connection:Disconnect()
            toggles.crate.connection = nil
        end
    end
end

