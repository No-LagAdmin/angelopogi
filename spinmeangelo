-- UI Helper Functions
local function makeToggle(txt, key)
    local btn = Instance.new("TextButton", container)
    btn.Size = UDim2.new(1, 0, 0, 40)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    btn.Text = txt .. ": OFF"
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.Gotham
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function()
        toggles[key] = not toggles[key]
        btn.Text = txt .. (toggles[key] and ": ON" or ": OFF")
        TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = toggles[key] and Color3.fromRGB(0, 150, 100) or Color3.fromRGB(35, 35, 45)}):Play()
    end)
end

local function makeSelector(txt, list, key)
    local frame = Instance.new("Frame", container)
    frame.Size = UDim2.new(1, 0, 0, 60)
    frame.BackgroundTransparency = 1
    
    local lbl = Instance.new("TextLabel", frame)
    lbl.Size = UDim2.new(1, 0, 0, 20); lbl.Text = "Select " .. txt; lbl.TextColor3 = Color3.new(0.7,0.7,0.7); lbl.Font = Enum.Font.Gotham; lbl.BackgroundTransparency = 1; lbl.TextXAlignment = 0
    
    local box = Instance.new("TextBox", frame)
    box.Size = UDim2.new(1, 0, 0, 35); box.Position = UDim2.new(0, 0, 0, 25)
    box.BackgroundColor3 = Color3.fromRGB(30, 30, 35); box.Text = selected[key]; box.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", box)
    
    box.FocusLost:Connect(function() selected[key] = box.Text end)
end

-- Build UI
makeToggle("Auto Collect Money", "AutoCollect")
makeToggle("Anti-AFK System", "AntiAFK")
makeToggle("Auto Buy Crates", "Crates")
makeToggle("Auto Use Potions", "Potions")
makeSelector("Crate Name (e.g. Heaven)", {}, "Crate")
makeSelector("Potion Name (e.g. Yen)", {}, "Potion")

-- Improved Dragging
local dragging, dragInput, dragStart, startPos
main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

print("✅ Angelo Hub V3 Loaded Successfully")
