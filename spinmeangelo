    selectBtn.MouseButton1Click:Connect(function()
        currentIndex = currentIndex + 1
        if currentIndex > #list then currentIndex = 1 end
        selections[key] = list[currentIndex]
        selectBtn.Text = "Select: " .. selections[key]
    end)
end

