-- ==========================================
-- STABLE BACKEND (Slot Indexing)
-- ==========================================

local function updateSlotCache()
    cachedButtons = {}
    pcall(function()
        -- Adjust "Plot1" if your plot name changes, or use a dynamic finder
        local plots = workspace:FindFirstChild("Plots")
        if plots then
            for _, plot in pairs(plots:GetChildren()) do
                local owner = plot:FindFirstChild("Owner")
                if owner and (owner.Value == player.Name or tostring(owner.Value) == tostring(player.UserId)) then
                    local slots = plot:FindFirstChild("Slots")
                    if slots then
                        for i = 1, 12 do
                            local slot = slots:FindFirstChild(tostring(i))
                            local btn = slot and slot:FindFirstChild("Button")
                            if btn then table.insert(cachedButtons, btn) end
                        end
                    end
                end
            end
        end
    end)
end

-- AUTO COLLECT LOOP (Repeat every 2 seconds)
task.spawn(function()
    while true do
        if toggles.AutoCollect then
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                if #cachedButtons == 0 then updateSlotCache() end
                for _, btn in pairs(cachedButtons) do
                    if not toggles.AutoCollect then break end
                    pcall(function()
                        firetouchinterest(btn, root, 0)
                        task.wait() -- Micro-wait to prevent crash
                        firetouchinterest(btn, root, 1)
                    end)
                end
            end
        end
        task.wait(2)
    end
end)

-- AUTO PURCHASE LOOP
task.spawn(function()
    while true do
        if toggles.Crates then
            for crate, _ in pairs(selectedCrates) do
                pcall(function() ReplicatedStorage.Events.Crate.purchase:FireServer(crate, 1) end)
                task.wait(0.5)
            end
        end
        if toggles.Potions then
            for potion, _ in pairs(selectedPotions) do
                pcall(function() ReplicatedStorage.Events.Potion.purchase:FireServer(potion, 1) end)
                task.wait(0.5)
            end
        end
        task.wait(2)
    end
end)

