        btn.Text = itemName
        btn.BackgroundColor3 = selectionTable[itemName] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(45, 45, 50)
        btn.TextColor3 = selectionTable[itemName] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 180)
