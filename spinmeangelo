-- AUTO COLLECT (Broad Search Version)
task.spawn(function()
    while true do
        if toggles.AutoCollect then
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                local myPlot = getMyPlot()
                
                pcall(function()
                    -- If we found a plot, scan it for anything clickable/touchable
                    if myPlot then
                        for _, obj in pairs(myPlot:GetDescendants()) do
                            if not toggles.AutoCollect then break end
                            
                            -- Method 1: Touch Interests (Buttons/Drops)
                            if obj:IsA("TouchTransmitter") then
