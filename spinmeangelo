local function makeToggle(txt, key, parent)
    local btn = Instance.new("TextButton", parent or scroll)
    btn.Size = UDim2.new(0.94, 0, 0, 40)
    btn.BackgroundColor3 = _G.toggles[key] and Color3.fromRGB(0, 180, 90) or Color3.fromRGB(30, 30, 40)
    btn.Text = txt; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.Gotham; Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function()
        _G.toggles[key] = not _G.toggles[key]
        btn.BackgroundColor3 = _G.toggles[key] and Color3.fromRGB(0, 180, 90) or Color3.fromRGB(30, 30, 40)
        saveConfig()
    end)
end

local function makeSection(titleTxt, toggleKey, items, targetTable)
    local sectionContainer = Instance.new("Frame", scroll)
    sectionContainer.Size = UDim2.new(0.94, 0, 0, 240); sectionContainer.BackgroundTransparency = 1
    local sList = Instance.new("UIListLayout", sectionContainer); sList.Padding = UDim.new(0, 8); sList.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local titleLab = Instance.new("TextLabel", sectionContainer)
    titleLab.Size = UDim2.new(1, 0, 0, 25); titleLab.Text = "--- SELECT " .. titleTxt:upper() .. " ---"
    titleLab.TextColor3 = Color3.fromRGB(0, 255, 150); titleLab.BackgroundTransparency = 1; titleLab.Font = Enum.Font.GothamBold; titleLab.TextSize = 13

    local gridFrame = Instance.new("Frame", sectionContainer)
    gridFrame.Size = UDim2.new(1, 0, 0, 150); gridFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 28); Instance.new("UICorner", gridFrame)

    local iScroll = Instance.new("ScrollingFrame", gridFrame)
    iScroll.Size = UDim2.new(1, -10, 1, -10); iScroll.Position = UDim2.new(0, 5, 0, 5); iScroll.BackgroundTransparency = 1; iScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    local grid = Instance.new("UIGridLayout", iScroll); grid.CellSize = UDim2.new(0, 100, 0, 30); grid.CellPadding = UDim2.new(0, 5, 0, 5)

    for _, name in pairs(items) do
        local b = Instance.new("TextButton", iScroll)
        b.Text = name; b.TextSize = 10; b.TextColor3 = Color3.new(1,1,1)
        b.BackgroundColor3 = targetTable[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(40, 40, 50); Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function()
            targetTable[name] = not targetTable[name]
            b.BackgroundColor3 = targetTable[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(40, 40, 50)
            saveConfig()
        end)
    end
    makeToggle("Enable Auto " .. titleTxt, toggleKey, sectionContainer)
end

