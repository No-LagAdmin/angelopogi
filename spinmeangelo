-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Logic Variables
local toggles = { AutoCollect = false, AntiAFK = false, Crates = false, Potions = false, EquipBest = false }
local selectedCrates = {}
local selectedPotions = {}

-- ==========================================
-- STABLE BACKEND (The "No-Crash" Engine)
-- ==========================================

task.spawn(function()
    while true do
        if toggles.AutoCollect then
            pcall(function()
                -- 1. Try Direct Remote (Fastest & Safest)
                local plotEvents = ReplicatedStorage:FindFirstChild("Events") and ReplicatedStorage.Events:FindFirstChild("Plot")
                if plotEvents and plotEvents:FindFirstChild("collectMoney") then
                    plotEvents.collectMoney:FireServer()
                else
                    -- 2. Physical Backup (Optimized to prevent crashing)
                    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                    if root then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v.Name == "Collect" and v:IsA("BasePart") then
                                firetouchinterest(v, root, 0)
                                task.wait(0.1)
                                firetouchinterest(v, root, 1)
                            end
                        end
                    end
                end
            end)
        end
        task.wait(2) -- Buffered wait to keep physics stable
    end
end)

-- Auto Buy/Equip Loop
task.spawn(function()
    while true do
        if toggles.Crates then
            for crate, _ in pairs(selectedCrates) do
                pcall(function() ReplicatedStorage.Events.Crate.purchase:FireServer(crate, 1) end)
                task.wait(0.5)
            end
        end
        if toggles.Potions then
            for potion, _ in pairs(selectedPotions) do
                pcall(function() ReplicatedStorage.Events.Potion.purchase:FireServer(potion, 1) end)
                task.wait(0.5)
            end
        end
        if toggles.EquipBest then
            pcall(function() ReplicatedStorage.Events.Plot.equipBest:InvokeServer() end)
        end
        task.wait(2)
    end
end)

