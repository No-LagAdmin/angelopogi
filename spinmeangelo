-- AUTO POTION (4H Cap -> Wait for 0)
task.spawn(function()
    local MAX_TIME = 14400 -- 4 Hours
    while true do
        if toggles.Potions then
            for item, _ in pairs(selectedPotions) do
                if not toggles.Potions or not selectedPotions[item] then continue end
                
                local currentTime = getPotionTime(item)
                
                if currentTime >= MAX_TIME then
                    waitingForReset[item] = true
                elseif currentTime <= 0 then
                    waitingForReset[item] = false
                end
                
                if not waitingForReset[item] then
                    pcall(function() ReplicatedStorage.Events.Potion.purchase:FireServer(item, 1) end)
                    task.wait(0.5)
                end
            end
        end
        task.wait(1)
    end
end)

-- AUTO CRATE
