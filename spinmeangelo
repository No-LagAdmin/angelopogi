-- AUTO COLLECT LOOP (Every 5 Seconds)
task.spawn(function()
    while true do
        if toggles.AutoCollect then
            pcall(function()
                local char = player.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                
                -- Strict Path: Workspace.Plots.Plot1
                local plot1 = workspace:FindFirstChild("Plots") and workspace.Plots:FindFirstChild("Plot1")
                
                if plot1 and root then
                    local slots = plot1:FindFirstChild("Slots")
                    if slots then
                        -- Strictly Slot 1 to Slot 12
                        for i = 1, 12 do
                            local slot = slots:FindFirstChild(tostring(i))
                            local btn = slot and slot:FindFirstChild("Button")
                            
                            if btn and btn:IsA("BasePart") then
                                firetouchinterest(btn, root, 0)
                                task.wait(0.05) -- Registration safety delay
                                firetouchinterest(btn, root, 1)
                            end
                        end
                    end
                end
            end)
        end
        task.wait(5) 
    end
end)

-- AUTO BUY/EQUIP LOOP
task.spawn(function()
    while true do
        if toggles.Crates then
            for crate, _ in pairs(selectedCrates) do
                pcall(function() ReplicatedStorage.Events.Crate.purchase:FireServer(crate, 1) end)
                task.wait(0.5)
            end
        end
        if toggles.Potions then
            for potion, _ in pairs(selectedPotions) do
                pcall(function() ReplicatedStorage.Events.Potion.purchase:FireServer(potion, 1) end)
                task.wait(0.5)
            end
        end
        task.wait(2)
    end
end)

