-- FUNCTION: CREATE SCROLLABLE DROPDOWN
local function createDropdownMenu(titleText, list, selectionTable, toggleKey)
    local outerFrame = Instance.new("Frame")
    outerFrame.Size = UDim2.new(0.95, 0, 0, 50)
    outerFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    outerFrame.ClipsDescendants = true
    outerFrame.Parent = container
    Instance.new("UICorner", outerFrame).CornerRadius = UDim.new(0, 10)

    local topBar = Instance.new("TextButton")
    topBar.Size = UDim2.new(1, 0, 0, 50)
    topBar.BackgroundTransparency = 1
    topBar.Text = "  " .. titleText
    topBar.TextColor3 = Color3.fromRGB(255, 255, 255)
    topBar.Font = Enum.Font.GothamBold
    topBar.TextSize = 14
    topBar.TextXAlignment = Enum.TextXAlignment.Left
    topBar.Parent = outerFrame

    local track = Instance.new("TextButton")
    track.Size = UDim2.new(0, 44, 0, 22)
    track.Position = UDim2.new(1, -55, 0, 14)
    track.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
    track.Text = ""
    track.Parent = outerFrame
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = UDim2.new(0, 2, 0.5, -9)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = track
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    -- THE SCROLLABLE LIST PART
    local listScroll = Instance.new("ScrollingFrame")
    listScroll.Size = UDim2.new(1, -20, 0, 150)
    listScroll.Position = UDim2.new(0, 10, 0, 55)
    listScroll.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    listScroll.BorderSizePixel = 0
    listScroll.ScrollBarThickness = 2
    listScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    listScroll.Parent = outerFrame
    Instance.new("UICorner", listScroll).CornerRadius = UDim.new(0, 8)

    local gLayout = Instance.new("UIGridLayout")
    gLayout.CellSize = UDim2.new(0, 95, 0, 30)
    gLayout.CellPadding = UDim2.new(0, 5, 0, 5)
    gLayout.Parent = listScroll

    for _, itemName in pairs(list) do
        local btn = Instance.new("TextButton")
        btn.Text = itemName
        btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
        btn.TextColor3 = Color3.fromRGB(180, 180, 180)
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 10
        btn.Parent = listScroll
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)

        btn.MouseButton1Click:Connect(function()
            if selectionTable[itemName] then
                selectionTable[itemName] = nil
                btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
                btn.TextColor3 = Color3.fromRGB(180, 180, 180)
            else
                selectionTable[itemName] = true
                btn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
                btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end)
    end

    local expanded = false
    topBar.MouseButton1Click:Connect(function()
        expanded = not expanded
        TweenService:Create(outerFrame, TweenInfo.new(0.3), {Size = expanded and UDim2.new(0.95, 0, 0, 215) or UDim2.new(0.95, 0, 0, 50)}):Play()
    end)

    track.MouseButton1Click:Connect(function()
        toggles[toggleKey] = not toggles[toggleKey]
        local active = toggles[toggleKey]
        local goalPos = active and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
        local goalCol = active and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(60, 60, 65)
        TweenService:Create(knob, TweenInfo.new(0.2), {Position = goalPos}):Play()
        TweenService:Create(track, TweenInfo.new(0.2), {BackgroundColor3 = goalCol}):Play()
        
        if active then
            task.spawn(function()
                while toggles[toggleKey] do
                    for item, _ in pairs(selectionTable) do
                        if not toggles[toggleKey] then break end
                        pcall(function() 
                            if toggleKey == "Crates" then
                                ReplicatedStorage.Events.Crate.purchase:FireServer(item, 1)
                            else
                                ReplicatedStorage.Events.Potion.purchase:FireServer(item, 1)
                            end
                        end)
                        task.wait(0.2)
                    end
                    task.wait(1)
                end
            end)
        end
    end)
end

