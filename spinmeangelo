-- 4. REMOTE HANDLER
local function fireStrictRemote(categoryName, itemName, amount)
    pcall(function()
        local events = ReplicatedStorage:FindFirstChild("Events")
        if events then
            local folder = events:FindFirstChild(categoryName)
            if folder then
                local remote = folder:FindFirstChild("open") or folder:FindFirstChild("purchase") or folder:FindFirstChild("use")
                if remote then 
                    if remote:IsA("RemoteFunction") then
                        task.spawn(function() remote:InvokeServer(itemName, amount or 1) end)
                    else
                        remote:FireServer(itemName, amount or 1) 
                    end
                end
            end
        end
    end)
end

