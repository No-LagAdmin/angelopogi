-- Optimized Plot Finder (Checks every possible way a plot is owned)
local function getMyPlot()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == "Owner" or obj.Name == "Player" or obj.Name == "OwnerName" then
            if obj:IsA("ValueBase") and (obj.Value == player.Name or tostring(obj.Value) == tostring(player.UserId)) then
                return obj.Parent -- Returns the Plot frame
            end
        end
    end
    return nil
end

-- AUTO COLLECT (Ultra-Aggressive Touch)
task.spawn(function()
    while true do
        if toggles.AutoCollect then
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                local plot = getMyPlot()
                pcall(function()
                    -- If plot found, touch everything inside it with a TouchInterest
                    if plot then
                        for _, v in pairs(plot:GetDescendants()) do
                            if v:IsA("TouchTransmitter") then
                                firetouchinterest(v.Parent, root, 0)
                                task.wait()
                                firetouchinterest(v.Parent, root, 1)
                            end
                        end
                    else
                        -- Backup: Touch anything nearby named 'Button' or 'Collect'
                        for _, v in pairs(workspace:GetChildren()) do
                            if (v.Name:find("Button") or v.Name:find("Collect")) and v:IsA("BasePart") then
                                if (v.Position - root.Position).Magnitude < 20 then
                                    firetouchinterest(v, root, 0)
                                    task.wait()
                                    firetouchinterest(v, root, 1)
                                end
                            end
                        end
                    end
                end)
            end
        end
        task.wait(4) -- Long wait to prevent AFK crashing
    end
end)

