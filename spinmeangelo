-- Functions for Remote Actions
local function buyCrates()
    local list = {"Porcelain", "Hell", "Ghost", "Abandoned", "Haunted", "Celestial", "Red Moon", "Vortex", "Cursed", "Devilous"}
    for _, c in pairs(list) do if not toggles.Crates then break end ReplicatedStorage.Events.Crate.purchase:FireServer(c, 1) task.wait(0.1) end
end

-- Custom Switch Component Creator
local function createSwitchRow(titleText, callback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, -5, 0, 50)
    row.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    row.Parent = container
    
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.Position = UDim2.new(0, 15, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = titleText
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = row
    
    -- Switch Track
    local track = Instance.new("TextButton")
    track.Name = "Track"
    track.Size = UDim2.new(0, 50, 0, 24)
    track.Position = UDim2.new(1, -65, 0.5, -12)
    track.BackgroundColor3 = Color3.fromRGB(70, 70, 75)
    track.Text = ""
    track.Parent = row
    
    local trackCorner = Instance.new("UICorner")
    trackCorner.CornerRadius = UDim.new(1, 0)
    trackCorner.Parent = track
    
    -- Switch Knob
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = UDim2.new(0, 4, 0.5, -9)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = track
    
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    
    local active = false
    track.MouseButton1Click:Connect(function()
        active = not active
        local goalPos = active and UDim2.new(1, -22, 0.5, -9) or UDim2.new(0, 4, 0.5, -9)
        local goalCol = active and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(70, 70, 75)
        
        TweenService:Create(knob, TweenInfo.new(0.2), {Position = goalPos}):Play()
        TweenService:Create(track, TweenInfo.new(0.2), {BackgroundColor3 = goalCol}):Play()
        
        callback(active)
    end)
end

-- Create Rows
createSwitchRow("Auto Buy Crates", function(state)
    toggles.Crates = state
    if state then task.spawn(function() while toggles.Crates do buyCrates() task.wait(3) end end) end
end)

createSwitchRow("Auto Buy Potions", function(state)
    toggles.Potions = state
    if state then
        task.spawn(function()
            local list = {"Yen", "Lucky", "Mutation", "Super Yen", "Super Lucky"}
            while toggles.Potions do
                for _, p in pairs(list) do if not toggles.Potions then break end ReplicatedStorage.Events.Potion.purchase:FireServer(p, 1) task.wait(0.1) end
                task.wait(3)
            end
        end)
    end
end)

createSwitchRow("Anti-AFK System", function(state)
    toggles.AntiAFK = state
    if state then
        task.spawn(function()
            local VU = game:GetService("VirtualUser")
            while toggles.AntiAFK do
                VU:CaptureController()
                VU:ClickButton2(Vector2.new())
                task.wait(30)
            end
        end)
    end
end)

createSwitchRow("Equip Best Items", function(state)
    toggles.EquipBest = state
    if state then
        task.spawn(function()
            while toggles.EquipBest do
                pcall(function() ReplicatedStorage.Events.Plot.equipBest:InvokeServer() end)
                task.wait(60)
            end
        end)
    end
end)

-- Draggable UI Logic
local dragging, dragInput, dragStart, startPos
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

game:GetService("UserInputService").InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)
