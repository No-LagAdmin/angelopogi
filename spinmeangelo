-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- File Settings
local filename = "AngeloPogi_Stable.json"

-- Logic Variables
local toggles = { Crates = false, Potions = false, AntiAFK = false, EquipBest = false, AutoCollect = false }
local selectedCrates = {}
local selectedPotions = {}

-- ==========================================
-- MEMORY & CONFIG MANAGEMENT
-- ==========================================
local function saveConfig()
    pcall(function() 
        if writefile then 
            writefile(filename, HttpService:JSONEncode({T = toggles, C = selectedCrates, P = selectedPotions})) 
        end 
    end)
end

local function loadConfig()
    pcall(function()
        if isfile and isfile(filename) then
            local d = HttpService:JSONDecode(readfile(filename))
            toggles = d.T or toggles; selectedCrates = d.C or {}; selectedPotions = d.P or {}
        end
    end)
end
loadConfig()

-- Memory Leak Prevention (Clears internal Lua cache)
task.spawn(function()
    while task.wait(60) do
        collectgarbage("collect")
    end
end)

-- ==========================================
-- THE FIX: REMOTE-BASED COLLECTION
-- ==========================================

task.spawn(function()
    while true do
        if toggles.AutoCollect then
            pcall(function()
                -- Spin a Anime often uses a specific Remote for collecting.
                -- We fire the 'Claim' or 'Collect' event directly to bypass physical touching.
                local plotEvent = ReplicatedStorage:FindFirstChild("Events") and ReplicatedStorage.Events:FindFirstChild("Plot")
                if plotEvent and plotEvent:FindFirstChild("collectMoney") then
                    plotEvent.collectMoney:FireServer()
                else
                    -- Fallback: If no direct remote, use the 'Humanoid' touch bypass
                    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                    if root then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v.Name == "Collect" and v:IsA("BasePart") then
                                firetouchinterest(v, root, 0)
                                task.wait()
                                firetouchinterest(v, root, 1)
                            end
                        end
                    end
                end
            end)
        end
        task.wait(5) -- Slow frequency = No Crash
    end
end)

-- AUTO CRATE & POTION (Buffered to prevent Network Overload)
task.spawn(function()
    while true do
        if toggles.Crates then
            for n, _ in pairs(selectedCrates) do
                ReplicatedStorage.Events.Crate.purchase:FireServer(n, 1)
                task.wait(2)
            end
        end
        if toggles.Potions then
            for n, _ in pairs(selectedPotions) do
                ReplicatedStorage.Events.Potion.purchase:FireServer(n, 1)
                task.wait(2)
            end
        end
        task.wait(2)
    end
end)

-- ==========================================
-- CLEAN & LIGHTWEIGHT UI
-- ==========================================
if playerGui:FindFirstChild("AngeloPogiHub") then playerGui.AngeloPogiHub:Destroy() end

local screenGui = Instance.new("ScreenGui", playerGui)
screenGui.Name = "AngeloPogiHub"

local main = Instance.new("Frame", screenGui)
main.Size = UDim2.new(0, 300, 0, 350)
main.Position = UDim2.new(0.5, -150, 0.5, -175)
main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Instance.new("UICorner", main)

local container = Instance.new("ScrollingFrame", main)
container.Size = UDim2.new(1, -10, 1, -20); container.Position = UDim2.new(0, 5, 0, 10)
container.BackgroundTransparency = 1; container.AutomaticCanvasSize = 2; container.ScrollBarThickness = 2
Instance.new("UIListLayout", container).Padding = UDim.new(0, 5)

-- Minimal Toggle Creator
local function makeToggle(txt, key)
    local btn = Instance.new("TextButton", container)
    btn.Size = UDim2.new(0.95, 0, 0, 35); btn.BackgroundColor3 = toggles[key] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
    btn.Text = txt; btn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function()
        toggles[key] = not toggles[key]
        btn.BackgroundColor3 = toggles[key] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(40, 40, 40)
        saveConfig()
    end)
end

-- Minimal Dropdown Creator
local function makeDrop(txt, list, selection, key)
    local dropFrame = Instance.new("Frame", container)
    dropFrame.Size = UDim2.new(0.95, 0, 0, 35); dropFrame.ClipsDescendants = true; dropFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", dropFrame)
    
    local btn = Instance.new("TextButton", dropFrame)
    btn.Size = UDim2.new(1, 0, 0, 35); btn.Text = txt; btn.BackgroundColor3 = Color3.fromRGB(50, 50, 70); btn.TextColor3 = Color3.new(1,1,1)
    
    local content = Instance.new("Frame", dropFrame)
    content.Position = UDim2.new(0, 0, 0, 40); content.Size = UDim2.new(1, 0, 0, 100)
    Instance.new("UIListLayout", content)

    for _, item in pairs(list) do
        local opt = Instance.new("TextButton", content)
        opt.Size = UDim2.new(1, 0, 0, 25); opt.Text = item; opt.BackgroundColor3 = selection[item] and Color3.fromRGB(0, 100, 200) or Color3.fromRGB(20, 20, 20)
        opt.MouseButton1Click:Connect(function()
            selection[item] = not selection[item] or nil
            opt.BackgroundColor3 = selection[item] and Color3.fromRGB(0, 100, 200) or Color3.fromRGB(20, 20, 20)
            saveConfig()
        end)
    end

    btn.MouseButton1Click:Connect(function()
        dropFrame.Size = (dropFrame.Size.Y.Offset == 35) and UDim2.new(0.95, 0, 0, 140) or UDim2.new(0.95, 0, 0, 35)
    end)
end

-- Build
makeToggle("Auto Collect Money", "AutoCollect")
makeToggle("Anti-AFK", "AntiAFK")
makeDrop("Select Crates", {"Heaven", "Cyber", "Magma", "Cursed"}, selectedCrates, "Crates")
makeDrop("Select Potions", {"Yen", "Lucky", "Angelic", "Greed"}, selectedPotions, "Potions")
makeToggle("Enable Auto Crates", "Crates")
makeToggle("Enable Auto Potions", "Potions")

-- Dragging
local d, ds, sp; main.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d = true; ds = i.Position; sp = main.Position end end)
UserInputService.InputChanged:Connect(function(i) if d and i.UserInputType == Enum.UserInputType.MouseMovement then local delta = i.Position - ds; main.Position = UDim2.new(sp.X.Scale, sp.X.Offset + delta.X, sp.Y.Scale, sp.Y.Offset + delta.Y) end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d = false end end)

print("✅ Indestructible Angelo Hub Loaded.")
