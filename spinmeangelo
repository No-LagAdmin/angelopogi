-- Reusable Components
local function createSwitch(titleText, toggleKey, callback)
    local row = Instance.new("Frame", container)
    row.Size = UDim2.new(0.95, 0, 0, 50)
    row.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    Instance.new("UICorner", row)
    
    local label = Instance.new("TextLabel", row)
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.Text = titleText; label.TextColor3 = Color3.fromRGB(200, 200, 200); label.Font = Enum.Font.Gotham; label.TextSize = 14; label.BackgroundTransparency = 1; label.TextXAlignment = 0
    
    local track = Instance.new("TextButton", row)
    track.Size = UDim2.new(0, 44, 0, 22); track.Position = UDim2.new(1, -55, 0.5, -11)
    track.BackgroundColor3 = toggles[toggleKey] and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(60, 60, 65); track.Text = ""
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    
    track.MouseButton1Click:Connect(function()
        toggles[toggleKey] = not toggles[toggleKey]
        track.BackgroundColor3 = toggles[toggleKey] and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(60, 60, 65)
        saveConfig()
        if callback then task.spawn(function() callback(toggles[toggleKey]) end) end
    end)
    if toggles[toggleKey] and callback then task.spawn(function() callback(true) end) end
end

local function createDropdown(titleText, list, selectionTable, toggleKey)
    local outerFrame = Instance.new("Frame", container)
    outerFrame.Size = UDim2.new(0.95, 0, 0, 50); outerFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 35); outerFrame.ClipsDescendants = true
    Instance.new("UICorner", outerFrame)

    local topBar = Instance.new("TextButton", outerFrame)
    topBar.Size = UDim2.new(1, 0, 0, 50); topBar.Text = "  " .. titleText; topBar.TextColor3 = Color3.new(1,1,1); topBar.Font = Enum.Font.GothamBold; topBar.BackgroundTransparency = 1; topBar.TextXAlignment = 0

    local listScroll = Instance.new("ScrollingFrame", outerFrame)
    listScroll.Size = UDim2.new(1, -20, 0, 130); listScroll.Position = UDim2.new(0, 10, 0, 55); listScroll.BackgroundTransparency = 1; listScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    local grid = Instance.new("UIGridLayout", listScroll); grid.CellSize = UDim2.new(0, 95, 0, 30)

    for _, itemName in pairs(list) do
        local btn = Instance.new("TextButton", listScroll)
        btn.Text = itemName; btn.BackgroundColor3 = selectionTable[itemName] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(45, 45, 50); btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.Gotham; btn.TextSize = 10
        Instance.new("UICorner", btn)
        btn.MouseButton1Click:Connect(function()
            selectionTable[itemName] = not selectionTable[itemName] or nil
            btn.BackgroundColor3 = selectionTable[itemName] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(45, 45, 50)
            saveConfig()
        end)
    end

    topBar.MouseButton1Click:Connect(function()
        local expanded = outerFrame.Size.Y.Offset == 50
        TweenService:Create(outerFrame, TweenInfo.new(0.3), {Size = expanded and UDim2.new(0.95, 0, 0, 200) or UDim2.new(0.95, 0, 0, 50)}):Play()
    end)
    createSwitch("Enable " .. titleText, toggleKey)
end

