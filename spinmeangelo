-- FUNCTION: CREATE MULTI-SELECT ROW
local function createMultiSelectRow(titleText, list, selectionTable, toggleCallback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(0.95, 0, 0, 150)
    row.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    row.Parent = container
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 10)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, 0, 0, 35)
    label.Position = UDim2.new(0, 12, 0, 5)
    label.BackgroundTransparency = 1
    label.Text = titleText
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = row

    local track = Instance.new("TextButton")
    track.Size = UDim2.new(0, 44, 0, 22)
    track.Position = UDim2.new(1, -55, 0, 12)
    track.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    track.Text = ""
    track.Parent = row
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    
    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = UDim2.new(0, 2, 0.5, -9)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = track
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local subScroll = Instance.new("ScrollingFrame")
    subScroll.Size = UDim2.new(1, -20, 0, 95)
    subScroll.Position = UDim2.new(0, 10, 0, 45)
    subScroll.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    subScroll.BorderSizePixel = 0
    subScroll.ScrollBarThickness = 2
    subScroll.Parent = row
    Instance.new("UICorner", subScroll).CornerRadius = UDim.new(0, 6)
    
    local subLayout = Instance.new("UIGridLayout")
    subLayout.CellSize = UDim2.new(0, 90, 0, 30)
    subLayout.CellPadding = UDim2.new(0, 5, 0, 5)
    subLayout.Parent = subScroll

    for _, itemName in ipairs(list) do
        local btn = Instance.new("TextButton")
        btn.Text = itemName
        btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
        btn.TextColor3 = Color3.fromRGB(150, 150, 150)
        btn.TextSize = 10
        btn.Font = Enum.Font.Gotham
        btn.Parent = subScroll
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)

        btn.MouseButton1Click:Connect(function()
            if selectionTable[itemName] then
                selectionTable[itemName] = nil
                TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(45, 45, 50), TextColor3 = Color3.fromRGB(150, 150, 150)}):Play()
            else
                selectionTable[itemName] = true
                TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 150, 255), TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
            end
        end)
    end
    
    subScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y

    track.MouseButton1Click:Connect(function()
        local active = not toggles[titleText:gsub(" ", "")]
        toggles[titleText:gsub(" ", "")] = active
        local goalPos = active and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
        local goalCol = active and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(50, 50, 55)
        TweenService:Create(knob, TweenInfo.new(0.2), {Position = goalPos}):Play()
        TweenService:Create(track, TweenInfo.new(0.2), {BackgroundColor3 = goalCol}):Play()
        toggleCallback(active)
    end)
end

