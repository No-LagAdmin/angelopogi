-- Helper Functions
local function createToggleButton(parent, internalName, displayName, position, callback, size)
    local btn = Instance.new("TextButton")
    btn.Name = internalName -- Use a fixed internal name for easy referencing
    btn.Size = size or UDim2.new(1, -20, 0, 40)
    btn.Position = position
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    btn.Text = displayName
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextScaled = true
    btn.Font = Enum.Font.Gotham
    btn.Parent = parent
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = btn
    
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- Remote Functions
local function buyCrate(crateName)
    pcall(function()
        ReplicatedStorage.Events.Crate.purchase:FireServer(crateName, 1)
    end)
end

local function buyPotion(potionName)
    pcall(function()
        ReplicatedStorage.Events.Potion.purchase:FireServer(potionName, 1)
    end)
end

-- Logic Toggles
local function toggleCrates()
    toggles.crate = not toggles.crate
    local btn = mainFrame.CratesFrame:FindFirstChild("CrateToggle")
    
    if toggles.crate then
        btn.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
        btn.Text = "🟢 Crates: ON"
        task.spawn(function()
            while toggles.crate do
                for _, crate in ipairs(crateList) do
                    if not toggles.crate then break end
                    buyCrate(crate)
                    task.wait(0.1)
                end
                task.wait(3)
            end
        end)
    else
        btn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        btn.Text = "🔴 Crates: OFF"
    end
end

local function togglePotions()
    toggles.potion = not toggles.potion
