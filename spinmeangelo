-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Variables
local toggles = { AutoCollect = false, AntiAFK = false, Potions = false, Crates = false }
local selectedCrates = {}
local selectedPotions = {}

-- ==========================================
-- STABLE CORE LOGIC
-- ==========================================

-- AUTO COLLECT (Uses direct remote fire to avoid physical UI lag)
task.spawn(function()
    while true do
        if toggles.AutoCollect then
            pcall(function()
                -- Direct Remote Fire (Most Stable)
                local remotes = ReplicatedStorage:FindFirstChild("Events")
                if remotes and remotes:FindFirstChild("Plot") and remotes.Plot:FindFirstChild("collectMoney") then
                    remotes.Plot.collectMoney:FireServer()
                else
                    -- Touch Fallback
                    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                    if root then
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v.Name == "Collect" and v:IsA("BasePart") then
                                firetouchinterest(v, root, 0)
                                task.wait()
                                firetouchinterest(v, root, 1)
                            end
                        end
                    end
                end
            end)
        end
        task.wait(4)
    end
end)

-- ANTI-AFK (Engine Level)
task.spawn(function()
    local vu = game:GetService("VirtualUser")
    player.Idled:Connect(function()
        if toggles.AntiAFK then
            vu:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
            task.wait(1)
            vu:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
        end
    end)
end)

-- ==========================================
-- MINIMALIST UI (Won't Break)
-- ==========================================
if playerGui:FindFirstChild("AngeloFix") then playerGui.AngeloFix:Destroy() end

local sg = Instance.new("ScreenGui", playerGui)
sg.Name = "AngeloFix"

local frame = Instance.new("Frame", sg)
frame.Size = UDim2.new(0, 200, 0, 250)
frame.Position = UDim2.new(0.1, 0, 0.1, 0)
frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
frame.Active = true
frame.Draggable = true -- Built-in draggable to save memory

local layout = Instance.new("UIListLayout", frame)
layout.Padding = UDim.new(0, 5)

local function quickBtn(txt, key)
    local b = Instance.new("TextButton", frame)
    b.Size = UDim2.new(1, 0, 0, 40)
    b.Text = txt .. ": OFF"
    b.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    b.TextColor3 = Color3.new(1,1,1)
    
    b.MouseButton1Click:Connect(function()
        toggles[key] = not toggles[key]
        b.Text = txt .. (toggles[key] and ": ON" or ": OFF")
        b.BackgroundColor3 = toggles[key] and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(50, 50, 50)
    end)
end

-- Create Buttons
quickBtn("Auto Collect", "AutoCollect")
quickBtn("Anti-AFK", "AntiAFK")
quickBtn("Auto Potions", "Potions")
quickBtn("Auto Crates", "Crates")

local close = Instance.new("TextButton", frame)
close.Size = UDim2.new(1, 0, 0, 20)
close.Text = "CLOSE UI (Keep Running)"
close.BackgroundColor3 = Color3.fromRGB(100, 0, 0)
close.TextColor3 = Color3.new(1,1,1)
close.MouseButton1Click:Connect(function() frame.Visible = false end)

