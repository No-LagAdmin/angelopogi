local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Logic Variables
local toggles = { AutoCollect = false, AntiAFK = false, Crates = false, Potions = false }
local selectedCrates = {}
local selectedPotions = {}
local isMinimized = false

-- ==========================================
-- THE FIX: SAFE-CHECK COLLECTION
-- ==========================================
task.spawn(function()
    while true do
        if toggles.AutoCollect then
            pcall(function()
                local char = player.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                
                -- Find your plot dynamically to avoid 'nil' errors
                local myPlot = nil
                for _, p in pairs(workspace.Plots:GetChildren()) do
                    local owner = p:FindFirstChild("Owner") or p:FindFirstChild("Player")
                    if owner and (tostring(owner.Value) == player.Name or owner.Value == player.UserId) then
                        myPlot = p
                        break
                    end
                end

                if myPlot and root then
                    local slots = myPlot:FindFirstChild("Slots")
                    if slots then
                        -- Check slots 1-12 with a safety check for each
                        for i = 1, 12 do
                            local slot = slots:FindFirstChild(tostring(i))
                            local btn = slot and slot:FindFirstChild("Button")
                            
                            -- Only fire if the button actually exists (prevents nil iteration)
                            if btn and btn:IsA("BasePart") then
                                firetouchinterest(btn, root, 0)
                                task.wait(0.02) -- Smallest safe delay
                                firetouchinterest(btn, root, 1)
                            end
                        end
                    end
                end
            end)
        end
        task.wait(1.5) -- Wait to prevent CoreScript Profiler overload
    end
end)

