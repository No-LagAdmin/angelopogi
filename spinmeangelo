-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Variables & Config
local toggles = { AutoCollect = false, AntiAFK = false, Potions = false, Crates = false }
local selected = { Crate = "Heaven", Potion = "Yen" }

-- ==========================================
-- STABLE BACKEND LOGIC
-- ==========================================

task.spawn(function()
    while true do
        if toggles.AutoCollect then
            pcall(function()
                local remote = ReplicatedStorage:FindFirstChild("Events") and ReplicatedStorage.Events:FindFirstChild("Plot")
                if remote and remote:FindFirstChild("collectMoney") then
                    remote.collectMoney:FireServer()
                end
            end)
        end
        if toggles.Crates then
            pcall(function() ReplicatedStorage.Events.Crate.purchase:FireServer(selected.Crate, 1) end)
        end
        if toggles.Potions then
            pcall(function() ReplicatedStorage.Events.Potion.purchase:FireServer(selected.Potion, 1) end)
        end
        task.wait(3)
    end
end)

