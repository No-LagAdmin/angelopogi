-- AUTO COLLECT (FIXED: Sequential processing to prevent crashing)
task.spawn(function()
    while true do
        if toggles.AutoCollect then
            local character = player.Character
            local root = character and character:FindFirstChild("HumanoidRootPart")
            
            if root then
                for p = 1, 12 do
                    if not toggles.AutoCollect then break end
                    local plot = workspace.Plots:FindFirstChild("Plot" .. p)
                    if plot then
                        for s = 1, 12 do
                            local slot = plot.Slots:FindFirstChild(tostring(s))
                            local button = slot and slot:FindFirstChild("Button")
                            if button and firetouchinterest then
                                firetouchinterest(button, root, 0)
                                task.wait()
                                firetouchinterest(button, root, 1)
                            end
                        end
                    end
                end
            end
        end
        task.wait(2) -- Increased to 2s to prevent lag/crashing
    end
end)

