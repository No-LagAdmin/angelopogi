-- ==========================================
-- CONFIGURATION SYSTEM (FORCE SAVE)
-- ==========================================
local function saveConfig()
    local data = { 
        Toggles = toggles, 
        Crates = selectedCrates, 
        Potions = selectedPotions 
    }
    pcall(function() 
        if writefile then 
            writefile(filename, HttpService:JSONEncode(data)) 
            print("💾 Angelo Hub: Saved to " .. filename)
        end 
    end)
end

local function loadConfig()
    pcall(function()
        if isfile and isfile(filename) then
            local decoded = HttpService:JSONDecode(readfile(filename))
            -- Merging data carefully
            for k, v in pairs(decoded.Toggles or {}) do toggles[k] = v end
            for k, v in pairs(decoded.Crates or {}) do selectedCrates[k] = v end
            for k, v in pairs(decoded.Potions or {}) do selectedPotions[k] = v end
            print("📂 Angelo Hub: Config Loaded")
        end
    end)
end

loadConfig()

