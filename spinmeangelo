local function makeToggle(txt, key)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0.96, 0, 0, 42)
    btn.BackgroundColor3 = _G.toggles[key] and Color3.fromRGB(0, 150, 80) or Color3.fromRGB(35, 35, 45)
    btn.Text = txt; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.Gotham; btn.TextSize = 13
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function()
        _G.toggles[key] = not _G.toggles[key]
        btn.BackgroundColor3 = _G.toggles[key] and Color3.fromRGB(0, 150, 80) or Color3.fromRGB(35, 35, 45)
        saveConfig()
    end)
end

local function makeGrid(txt, list, tab)
    local lbl = Instance.new("TextLabel", scroll)
    lbl.Size = UDim2.new(1, 0, 0, 25); lbl.Text = txt; lbl.TextColor3 = Color3.new(0.6,0.6,0.6)
    lbl.Font = Enum.Font.Gotham; lbl.TextXAlignment = Enum.TextXAlignment.Center; lbl.BackgroundTransparency = 1

    local gFrame = Instance.new("Frame", scroll)
    gFrame.Size = UDim2.new(0.96, 0, 0, 125); gFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    Instance.new("UICorner", gFrame)

    local gScroll = Instance.new("ScrollingFrame", gFrame)
    gScroll.Size = UDim2.new(1, -10, 1, -10); gScroll.Position = UDim2.new(0, 5, 0, 5)
    gScroll.BackgroundTransparency = 1; gScroll.CanvasSize = UDim2.new(0,0,5,0); gScroll.ScrollBarThickness = 0
    local grid = Instance.new("UIGridLayout", gScroll); grid.CellSize = UDim2.new(0, 100, 0, 28); grid.HorizontalAlignment = Enum.HorizontalAlignment.Center

    for _, name in pairs(list) do
        local b = Instance.new("TextButton", gScroll)
        b.Text = name; b.Font = Enum.Font.Gotham; b.TextSize = 10; b.TextColor3 = Color3.new(1,1,1)
        b.BackgroundColor3 = tab[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(45, 45, 55)
        Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function()
            if tab[name] then tab[name] = nil else tab[name] = true end
            b.BackgroundColor3 = tab[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(45, 45, 55)
            saveConfig()
        end)
    end
end

