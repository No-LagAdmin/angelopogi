-- UI Builders
local function makeToggle(txt, key)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0.95, 0, 0, 38)
    btn.BackgroundColor3 = toggles[key] and Color3.fromRGB(0, 180, 100) or Color3.fromRGB(35, 35, 45)
    btn.Text = txt; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.Gotham
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function()
        toggles[key] = not toggles[key]
        btn.BackgroundColor3 = toggles[key] and Color3.fromRGB(0, 180, 100) or Color3.fromRGB(35, 35, 45)
    end)
end

local function makeGrid(txt, list, tab)
    local lbl = Instance.new("TextLabel", scroll)
    lbl.Size = UDim2.new(1, 0, 0, 20); lbl.Text = "  " .. txt; lbl.TextColor3 = Color3.new(0.6,0.6,0.6)
    lbl.Font = Enum.Font.Gotham; lbl.TextXAlignment = 0; lbl.BackgroundTransparency = 1

    local gFrame = Instance.new("Frame", scroll)
    gFrame.Size = UDim2.new(0.95, 0, 0, 110); gFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    Instance.new("UICorner", gFrame)

    local gScroll = Instance.new("ScrollingFrame", gFrame)
    gScroll.Size = UDim2.new(1, -10, 1, -10); gScroll.Position = UDim2.new(0, 5, 0, 5)
    gScroll.BackgroundTransparency = 1; gScroll.CanvasSize = UDim2.new(0,0,2,0); gScroll.ScrollBarThickness = 0
    local grid = Instance.new("UIGridLayout", gScroll); grid.CellSize = UDim2.new(0, 92, 0, 25)

    for _, name in pairs(list) do
        local b = Instance.new("TextButton", gScroll)
        b.Text = name; b.Font = Enum.Font.Gotham; b.TextSize = 10; b.TextColor3 = Color3.new(1,1,1)
        b.BackgroundColor3 = tab[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(45, 45, 55)
        Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function()
            tab[name] = not tab[name] or nil
            b.BackgroundColor3 = tab[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(45, 45, 55)
        end)
    end
end

