-- AUTO COLLECT & EQUIP
task.spawn(function()
    while task.wait(5) do
        if _G.toggles.AutoCollect then
            pcall(function()
                local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                local slots = workspace.Plots.Plot1.Slots
                if root and slots then
                    for i = 1, 12 do
                        local btn = slots[tostring(i)]:FindFirstChild("Button")
                        if btn then firetouchinterest(btn, root, 0) task.wait(0.01) firetouchinterest(btn, root, 1) end
                    end
                end
            end)
        end
    end
end)

task.spawn(function()
    while task.wait(25) do
        if _G.toggles.EquipBest then
            pcall(function()
                local remote = ReplicatedStorage.Events.Plot.equipBest
                if remote:IsA("RemoteFunction") then remote:InvokeServer() else remote:FireServer() end
            end)
        end
    end
end)

-- AUTO BUY CRATES/POTIONS
task.spawn(function()
    while task.wait(1.5) do
        if _G.toggles.Crates then
            for crate, state in pairs(_G.selectedCrates) do
                if state then ReplicatedStorage.Events.Crate.purchase:FireServer(crate, 1) task.wait(0.3) end
            end
        end
        if _G.toggles.Potions then
            for pot, state in pairs(_G.selectedPotions) do
                if state then ReplicatedStorage.Events.Potion.purchase:FireServer(pot, 1) task.wait(0.3) end
            end
        end
    end
end)

