-- Find your plot by scanning all possible owner indicators
local function getMyPlot()
    local plots = workspace:FindFirstChild("Plots") or workspace:FindFirstChild("Tycoons")
    if not plots then return nil end
    
    for _, plot in pairs(plots:GetChildren()) do
        -- Check Value Objects (Owner, Player, User)
        for _, child in pairs(plot:GetChildren()) do
            if child:IsA("ValueBase") and (child.Value == player.Name or tostring(child.Value) == tostring(player.UserId)) then
                return plot
            end
        end
        -- Check Attributes
        if plot:GetAttribute("Owner") == player.UserId or plot:GetAttribute("OwnerName") == player.Name then
            return plot
        end
    end
    return nil
end

