-- File Settings
local filename = "AngeloPogiHub_Config.json"

-- Logic Variables
local toggles = { Crates = false, Potions = false, AntiAFK = false, EquipBest = false, AutoCollect = false }
local selectedCrates = {}
local selectedPotions = {}
local waitingForReset = {} 

-- ==========================================
-- CONFIGURATION SYSTEM
-- ==========================================
local function saveConfig()
    local data = { Toggles = toggles, Crates = selectedCrates, Potions = selectedPotions }
    pcall(function() if writefile then writefile(filename, HttpService:JSONEncode(data)) end end)
end

local function loadConfig()
    if isfile and isfile(filename) then
        pcall(function()
            local decoded = HttpService:JSONDecode(readfile(filename))
            if decoded.Toggles then for k, v in pairs(decoded.Toggles) do toggles[k] = v end end
            if decoded.Crates then for k, v in pairs(decoded.Crates) do selectedCrates[k] = v end end
            if decoded.Potions then for k, v in pairs(decoded.Potions) do selectedPotions[k] = v end end
        end)
    end
end

loadConfig()

-- Potion Logic Fix
local function getPotionTime(potionName)
    local dataFolder = player:FindFirstChild("Data") or player:FindFirstChild("leaderstats")
    if dataFolder then
        local sub = dataFolder:FindFirstChild("Potions")
        local target = (sub and sub:FindFirstChild(potionName)) or dataFolder:FindFirstChild(potionName)
        if target and target:IsA("ValueBase") then 
            return tonumber(target.Value) or 0 -- Fixes comparison error
        end
    end
    return tonumber(player:GetAttribute(potionName)) or 0
end

-- ==========================================
-- LOOPS
-- ==========================================

task.spawn(function()
    while true do
        if toggles.Potions then
            for item, _ in pairs(selectedPotions) do
                local currentTime = getPotionTime(item)
                if currentTime >= 14400 then waitingForReset[item] = true
                elseif currentTime <= 0 then waitingForReset[item] = false end
                
                if not waitingForReset[item] then
                    pcall(function() ReplicatedStorage.Events.Potion.purchase:FireServer(item, 1) end)
                    task.wait(0.5)
                end
            end
        end
        task.wait(1)
    end
end)

task.spawn(function()
    while true do
        if toggles.AutoCollect then
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                for p = 1, 12 do
                    local plot = workspace.Plots:FindFirstChild("Plot" .. p)
                    if plot then
                        for s = 1, 12 do
                            if not toggles.AutoCollect then break end
                            local btn = plot.Slots:FindFirstChild(tostring(s)) and plot.Slots[tostring(s)]:FindFirstChild("Button")
                            if btn then firetouchinterest(btn, root, 0); task.wait(); firetouchinterest(btn, root, 1) end
                        end
                    end
                end
            end
        end
        task.wait(2)
    end
end)

