-- BACKEND LOOPS
-- ==========================================

task.spawn(function()
    while true do
        if _G.toggles.EquipBest then
            pcall(function()
                local remote = ReplicatedStorage.Events.Plot.equipBest
                if remote:IsA("RemoteFunction") then task.spawn(function() remote:InvokeServer() end) else remote:FireServer() end
            end)
        end
        task.wait(25)
    end
end)

task.spawn(function()
    while true do
        if _G.toggles.AutoCollect then
            pcall(function()
                local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                local slots = workspace.Plots.Plot1.Slots
                if root and slots then
                    for i = 1, 12 do
                        local btn = slots[tostring(i)]:FindFirstChild("Button")
                        if btn then
                            firetouchinterest(btn, root, 0)
                            task.wait(0.03)
                            firetouchinterest(btn, root, 1)
                        end
                    end
                end
            end)
        end
        task.wait(5)
    end
end)

-- ==========================================
-- UI FORCE-LOAD (The Fix)
-- ==========================================
if not playerGui then warn("❌ FATAL: PlayerGui not found. Execution stopped.") return end
if playerGui:FindFirstChild("AngeloFinalHub") then playerGui.AngeloFinalHub:Destroy() end

local sg = Instance.new("ScreenGui")
sg.Name = "AngeloFinalHub"
sg.Parent = playerGui
sg.ResetOnSpawn = false

local main = Instance.new("Frame", sg)
main.Size = UDim2.new(0, 360, 0, 500)
main.Position = UDim2.new(0.5, -180, 0.5, -250)
main.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
main.BorderSizePixel = 0
Instance.new("UICorner", main)

local header = Instance.new("Frame", main)
header.Size = UDim2.new(1, 0, 0, 50)
header.BackgroundColor3 = Color3.fromRGB(28, 28, 38)
Instance.new("UICorner", header)

local title = Instance.new("TextLabel", header)
title.Size = UDim2.new(1, 0, 1, 0)
title.Text = "ANGELO FULL POWER SPECIAL EDITION"
title.TextColor3 = Color3.fromRGB(0, 255, 150)
title.Font = Enum.Font.GothamBold; title.TextSize = 14; title.BackgroundTransparency = 1

local scroll = Instance.new("ScrollingFrame", main)
scroll.Size = UDim2.new(1, -20, 1, -60); scroll.Position = UDim2.new(0, 10, 0, 60)
scroll.BackgroundTransparency = 1; scroll.ScrollBarThickness = 2; scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
Instance.new("UIListLayout", scroll).Padding = UDim.new(0, 8)

local function makeToggle(txt, key)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0.96, 0, 0, 42)
    btn.BackgroundColor3 = _G.toggles[key] and Color3.fromRGB(0, 150, 80) or Color3.fromRGB(35, 35, 45)
    btn.Text = txt; btn.TextColor3 = Color3.new(1,1,1); btn.Font = Enum.Font.Gotham
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function()
        _G.toggles[key] = not _G.toggles[key]
        btn.BackgroundColor3 = _G.toggles[key] and Color3.fromRGB(0, 150, 80) or Color3.fromRGB(35, 35, 45)
        saveConfig()
    end)
end

-- UI Sections
makeToggle("Auto Collect Yen (Slots 1-12)", "AutoCollect")
makeToggle("Auto Equip Best (25s)", "EquipBest")
makeToggle("Anti-AFK System", "AntiAFK")

-- Dragging Logic
local dragging, dragStart, startPos
header.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; dragStart = i.Position; startPos = main.Position end end)
UserInputService.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then local delta = i.Position - dragStart; main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

print("✅ Angelo Final Hub v5.6 Loaded Successfully.")
