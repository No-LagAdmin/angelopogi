local function createSwitch(text, key, callback)
    local row = Instance.new("Frame", container)
    row.Size = UDim2.new(0.95, 0, 0, 45); row.BackgroundColor3 = Color3.fromRGB(28, 28, 35); Instance.new("UICorner", row)
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(0.7, 0, 1, 0); lbl.Position = UDim2.new(0, 12, 0, 0); lbl.Text = text; lbl.TextColor3 = Color3.new(0.8,0.8,0.8); lbl.BackgroundTransparency = 1; lbl.TextXAlignment = 0
    local btn = Instance.new("TextButton", row)
    btn.Size = UDim2.new(0, 40, 0, 20); btn.Position = UDim2.new(1, -50, 0.5, -10)
    btn.BackgroundColor3 = toggles[key] and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(60, 60, 70); btn.Text = ""
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)
    btn.MouseButton1Click:Connect(function()
        toggles[key] = not toggles[key]
        btn.BackgroundColor3 = toggles[key] and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(60, 60, 70)
        saveConfig() -- SAVE ON CLICK
        if callback then task.spawn(function() callback(toggles[key]) end) end
    end)
end

local function createDropdown(text, list, selection, key)
    local frame = Instance.new("Frame", container)
    frame.Size = UDim2.new(0.95, 0, 0, 45); frame.BackgroundColor3 = Color3.fromRGB(28, 28, 35); frame.ClipsDescendants = true; Instance.new("UICorner", frame)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1, 0, 0, 45); btn.Text = "  " .. text; btn.TextColor3 = Color3.new(1,1,1); btn.BackgroundTransparency = 1; btn.TextXAlignment = 0
    local inner = Instance.new("ScrollingFrame", frame)
    inner.Size = UDim2.new(1, -20, 0, 120); inner.Position = UDim2.new(0, 10, 0, 50); inner.BackgroundTransparency = 1; inner.AutomaticCanvasSize = 2
    Instance.new("UIGridLayout", inner).CellSize = UDim2.new(0, 90, 0, 25)

    for _, name in pairs(list) do
        local opt = Instance.new("TextButton", inner)
        opt.Text = name; opt.BackgroundColor3 = selection[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(40, 40, 50); opt.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", opt)
        opt.MouseButton1Click:Connect(function()
            if selection[name] then selection[name] = nil else selection[name] = true end
            opt.BackgroundColor3 = selection[name] and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(40, 40, 50)
            saveConfig() -- SAVE ON SELECTION
        end)
    end
    btn.MouseButton1Click:Connect(function()
        local expanded = frame.Size.Y.Offset == 45
        TweenService:Create(frame, TweenInfo.new(0.3), {Size = expanded and UDim2.new(0.95, 0, 0, 180) or UDim2.new(0.95, 0, 0, 45)}):Play()
    end)
    createSwitch("Enable " .. text, key)
end

