-- 2. ROBUST SAVE/LOAD SYSTEM
local function saveSettings()
    local data = {
        toggles = _G.toggles,
        crates = _G.selectedCrates,
        potions = _G.selectedPotions,
        fastCrates = _G.FastCrateActive
    }
    local success, encoded = pcall(function() return HttpService:JSONEncode(data) end)
    if success then
        writefile("AngeloHub_Config.json", encoded)
    end
end

local function loadSettings()
    if isfile and isfile("AngeloHub_Config.json") then
        local success, content = pcall(function() return readfile("AngeloHub_Config.json") end)
        if success then
            local data = HttpService:JSONDecode(content)
            if data.toggles then _G.toggles = data.toggles end
            if data.crates then _G.selectedCrates = data.crates end
            if data.potions then _G.selectedPotions = data.potions end
            if data.fastCrates then _G.FastCrateActive = data.fastCrates end
        end
    end
end

